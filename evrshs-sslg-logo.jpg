<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SUMAT Eastvicians</title>
  <script src="config.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            eastBlue: '#0b4f9f',
            deepBlue: '#073b7a',
            eastYellow: '#ffd447',
            gold: '#f5b700'
          },
          boxShadow: {
            glow: '0 24px 90px rgba(11, 79, 159, 0.28)',
            gold: '0 16px 48px rgba(245, 183, 0, 0.28)'
          },
          animation: {
            'brand-rise': 'brandRise 1.2s ease-out both',
            'soft-pulse': 'softPulse 2.6s ease-in-out infinite',
            'draw-line': 'drawLine 1s ease-out 0.7s both',
            'success-pop': 'successPop 560ms cubic-bezier(0.18, 0.89, 0.32, 1.28) both'
          },
          keyframes: {
            brandRise: {
              '0%': { opacity: '0', transform: 'translateY(18px) scale(0.94)', filter: 'blur(8px)' },
              '100%': { opacity: '1', transform: 'translateY(0) scale(1)', filter: 'blur(0)' }
            },
            softPulse: {
              '0%, 100%': { transform: 'scale(1)', opacity: '0.88' },
              '50%': { transform: 'scale(1.04)', opacity: '1' }
            },
            drawLine: {
              '0%': { width: '0', opacity: '0' },
              '100%': { width: '100%', opacity: '1' }
            },
            successPop: {
              '0%': { opacity: '0', transform: 'scale(0.45) rotate(-18deg)' },
              '100%': { opacity: '1', transform: 'scale(1) rotate(0)' }
            }
          }
        }
      }
    };
  </script>
  <style>
    html { scroll-behavior: smooth; }

    body {
      min-height: 100vh;
      overflow-x: hidden;
      background:
        radial-gradient(circle at top left, rgba(255, 212, 71, 0.28), transparent 31rem),
        radial-gradient(circle at bottom right, rgba(11, 79, 159, 0.26), transparent 34rem),
        linear-gradient(135deg, #f8fbff 0%, #eef7ff 42%, #fff8da 100%);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: #102033;
    }

    .view {
      opacity: 0;
      transform: translateY(14px) scale(0.985);
      transition: opacity 520ms ease, transform 520ms ease;
    }

    .view.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    .field {
      width: 100%;
      border: 1px solid rgba(11, 79, 159, 0.18);
      background: rgba(255, 255, 255, 0.92);
      border-radius: 1rem;
      padding: 0.85rem 1rem;
      color: #102033;
      outline: none;
      transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease, background 180ms ease;
    }

    .field:hover {
      border-color: rgba(11, 79, 159, 0.42);
      background: #ffffff;
    }

    .field:focus {
      border-color: #0b4f9f;
      box-shadow: 0 0 0 4px rgba(11, 79, 159, 0.14), 0 10px 28px rgba(11, 79, 159, 0.08);
      transform: translateY(-1px);
    }

    .field-label {
      display: block;
      margin-bottom: 0.45rem;
      color: #16375f;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .glass-card {
      position: relative;
      border: 1px solid rgba(255, 255, 255, 0.72);
      background: rgba(255, 255, 255, 0.82);
      box-shadow: 0 26px 80px rgba(7, 59, 122, 0.18);
      backdrop-filter: blur(20px);
    }

    .glass-card::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      border-radius: inherit;
      background: linear-gradient(135deg, rgba(255, 212, 71, 0.18), transparent 35%, rgba(11, 79, 159, 0.13));
    }

    .secure-grid {
      background-image:
        linear-gradient(rgba(11, 79, 159, 0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(11, 79, 159, 0.06) 1px, transparent 1px);
      background-size: 34px 34px;
      mask-image: linear-gradient(to bottom, black, transparent);
    }

    .logo-seal { filter: drop-shadow(0 16px 30px rgba(7, 59, 122, 0.28)); }

    select {
      appearance: none;
      background-image:
        linear-gradient(45deg, transparent 50%, #0b4f9f 50%),
        linear-gradient(135deg, #0b4f9f 50%, transparent 50%);
      background-position:
        calc(100% - 22px) calc(50% - 3px),
        calc(100% - 16px) calc(50% - 3px);
      background-size: 6px 6px, 6px 6px;
      background-repeat: no-repeat;
      padding-right: 2.7rem;
    }

    /* Confidentiality option cards added for the new privacy workflow. */
    .privacy-input:focus-visible + .privacy-card {
      outline: 3px solid rgba(11, 79, 159, 0.28);
      outline-offset: 3px;
    }

    .privacy-input:checked + .privacy-card {
      border-color: #0b4f9f;
      background: #edf6ff;
      box-shadow: 0 12px 28px rgba(11, 79, 159, 0.12);
    }

    .privacy-input:checked + .privacy-card .privacy-check {
      background: #0b4f9f;
      border-color: #0b4f9f;
      color: #ffffff;
    }

    .priority-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border-radius: 999px;
      padding: 0.45rem 0.75rem;
      font-size: 0.75rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .priority-high { background: #fee2e2; color: #b91c1c; }
    .priority-medium { background: #fef3c7; color: #a16207; }
    .priority-low { background: #dcfce7; color: #15803d; }

    .file-input::file-selector-button {
      margin-right: 0.8rem;
      border: 0;
      border-radius: 0.75rem;
      background: #0b4f9f;
      color: #ffffff;
      padding: 0.64rem 0.85rem;
      font-weight: 800;
      cursor: pointer;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 0.4rem 0.72rem;
      background: #e8f3ff;
      color: #0b4f9f;
      font-size: 0.75rem;
      font-weight: 900;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 1ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
        transition-duration: 1ms !important;
      }
    }
  </style>
</head>
<body>
  <main class="relative min-h-screen overflow-hidden">
    <div class="secure-grid pointer-events-none absolute inset-x-0 top-0 h-64"></div>

    <!-- Existing project splash retained; messaging now reflects confidentiality. -->
    <section id="introView" class="view is-visible grid min-h-screen place-items-center px-5 py-10">
      <div class="mx-auto w-full max-w-4xl text-center">
        <div class="mx-auto mb-8 flex h-32 w-32 items-center justify-center rounded-[2rem] border border-white/80 bg-white/70 p-2 shadow-glow backdrop-blur sm:h-36 sm:w-36">
          <img src="evrshs-sslg-logo.jpg" alt="EVRSHS SSLG logo" class="logo-seal h-full w-full rounded-[1.55rem] object-cover animate-soft-pulse" />
        </div>
        <p class="mb-4 text-sm font-black uppercase tracking-[0.34em] text-eastBlue">Confidential Student Voice Portal</p>
        <h1 class="animate-brand-rise text-balance text-5xl font-black leading-tight text-deepBlue sm:text-7xl lg:text-8xl">
          SUMAT <span class="text-gold">Eastvicians</span>
        </h1>
        <div class="mx-auto mt-7 h-1 max-w-xl overflow-hidden rounded-full bg-white/70">
          <div class="h-full rounded-full bg-gradient-to-r from-eastBlue via-gold to-eastBlue animate-draw-line"></div>
        </div>
        <p class="mx-auto mt-7 max-w-2xl text-base font-semibold leading-8 text-slate-700 sm:text-lg">
          Confidential Digital Reporting and Feedback System
        </p>
      </div>
    </section>

    <!-- Existing consent step retained before the new verification screen. -->
    <section id="consentView" class="view hidden min-h-screen px-5 py-8 sm:py-12">
      <div class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-5xl items-center justify-center">
        <div class="glass-card w-full overflow-hidden rounded-[2rem]">
          <div class="relative grid gap-0 lg:grid-cols-[0.82fr_1.18fr]">
            <aside class="relative overflow-hidden bg-gradient-to-br from-deepBlue via-eastBlue to-blue-600 p-8 text-white sm:p-10">
              <div class="absolute -right-16 -top-16 h-44 w-44 rounded-full bg-eastYellow/25 blur-2xl"></div>
              <div class="absolute bottom-8 left-8 h-24 w-24 rounded-[2rem] border border-eastYellow/35"></div>
              <div class="relative z-10 flex min-h-full flex-col justify-between gap-10">
                <div>
                  <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-bold backdrop-blur">
                    <span class="h-2.5 w-2.5 rounded-full bg-eastYellow"></span>
                    Privacy First
                  </div>
                  <h2 class="text-4xl font-black leading-tight sm:text-5xl">Your voice stays protected.</h2>
                  <p class="mt-5 text-base font-medium leading-8 text-blue-50">
                    SUMAT Eastvicians uses confidential reporting so concerns can be handled responsibly and safely.
                  </p>
                </div>
                <div class="rounded-2xl border border-white/20 bg-white/10 p-5 backdrop-blur">
                  <p class="text-sm font-bold uppercase tracking-[0.2em] text-eastYellow">SSLG</p>
                  <p class="mt-2 text-sm leading-6 text-blue-50">SSLG officers see report counts and trends only, never confidential report details or identities.</p>
                </div>
              </div>
            </aside>

            <div class="relative p-7 sm:p-10 lg:p-12">
              <div class="relative z-10">
                <p class="text-sm font-black uppercase tracking-[0.26em] text-eastBlue">Step 1</p>
                <h2 class="mt-3 text-3xl font-black text-slate-950 sm:text-4xl">Data Privacy Consent</h2>
                <div class="mt-7 rounded-3xl border border-blue-100 bg-white/82 p-6 shadow-sm sm:p-8">
                  <p class="text-lg font-semibold leading-9 text-slate-700">
                    I voluntarily authorize the SSLG to collect and process the information I provide for the purpose of understanding student needs, improving services, and strengthening student leadership. I understand that my data will be handled responsibly and confidentially, in accordance with RA 10173 (Data Privacy Act of 2012), and will not be shared without my consent unless required by law. Your voice matters. Please confirm your consent to continue.
                  </p>
                </div>
                <button id="agreeButton" type="button" class="mt-8 inline-flex w-full items-center justify-center gap-3 rounded-2xl bg-gradient-to-r from-eastBlue to-deepBlue px-7 py-4 text-base font-black text-white shadow-glow transition duration-200 hover:-translate-y-0.5 hover:shadow-2xl focus:outline-none focus:ring-4 focus:ring-eastBlue/25 sm:w-auto">
                  <span class="grid h-7 w-7 place-items-center rounded-full bg-eastYellow text-deepBlue" aria-hidden="true">
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none"><path d="M16.7 5.8 8.3 14.2 3.3 9.2" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </span>
                  I Agree and Continue
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- New student information verification step. -->
    <section id="verificationView" class="view hidden min-h-screen px-5 py-8 sm:py-12">
      <div class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-5xl items-center justify-center">
        <div class="glass-card w-full overflow-hidden rounded-[2rem]">
          <div class="relative grid gap-0 lg:grid-cols-[0.78fr_1.22fr]">
            <aside class="relative overflow-hidden bg-gradient-to-br from-deepBlue via-eastBlue to-blue-600 p-8 text-white sm:p-10">
              <div class="absolute -right-16 -top-16 h-44 w-44 rounded-full bg-eastYellow/25 blur-2xl"></div>
              <div class="relative z-10 flex h-full flex-col justify-between gap-10">
                <div>
                  <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-eastYellow text-2xl font-black text-deepBlue">ID</div>
                  <p class="text-sm font-black uppercase tracking-[0.26em] text-eastYellow">Source Verification</p>
                  <h2 class="mt-3 text-4xl font-black leading-tight">Confidential, not public.</h2>
                  <p class="mt-5 text-base font-medium leading-8 text-blue-50">Your details support responsible follow-up and remain visible only to authorized school officials when necessary.</p>
                </div>
                <div class="rounded-2xl border border-white/20 bg-white/10 p-5 backdrop-blur">
                  <p class="text-sm font-black uppercase tracking-[0.14em] text-eastYellow">Authorized Access</p>
                  <p class="mt-2 text-sm leading-6 text-blue-50">Principal, Guidance Counselor, Child Protection Committee, and Designated School Administrator.</p>
                </div>
              </div>
            </aside>

            <div class="relative p-7 sm:p-10 lg:p-12">
              <form id="verificationForm" class="relative z-10" novalidate>
                <p class="text-sm font-black uppercase tracking-[0.26em] text-eastBlue">Step 2</p>
                <h2 class="mt-3 text-3xl font-black text-slate-950 sm:text-4xl">Student Information Verification</h2>
                <p class="mt-3 text-sm font-semibold leading-6 text-slate-600">Verification is required before you can create a confidential report.</p>

                <div class="mt-7 grid gap-5 sm:grid-cols-2">
                  <div class="sm:col-span-2">
                    <label class="field-label" for="verifiedName">Full Name *</label>
                    <input id="verifiedName" name="verified_full_name" type="text" class="field" autocomplete="name" required />
                  </div>
                  <div>
                    <label class="field-label" for="verifiedGrade">Grade Level *</label>
                    <select id="verifiedGrade" name="verified_grade_level" class="field" required>
                      <option value="" selected disabled>Select grade level</option>
                      <option value="Grade 7">Grade 7</option>
                      <option value="Grade 8">Grade 8</option>
                      <option value="Grade 9">Grade 9</option>
                      <option value="Grade 10">Grade 10</option>
                      <option value="Grade 11">Grade 11</option>
                      <option value="Grade 12">Grade 12</option>
                    </select>
                  </div>
                  <div>
                    <label class="field-label" for="verifiedSection">Section *</label>
                    <input id="verifiedSection" name="verified_section" type="text" class="field" placeholder="e.g., Newtown" required />
                  </div>
                  <div class="sm:col-span-2">
                    <label class="field-label" for="verifiedId">Learner Reference Number (LRN) or Student ID</label>
                    <input id="verifiedId" name="verified_student_id" type="text" inputmode="numeric" class="field" placeholder="Optional if not available" />
                  </div>
                </div>

                <p class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm font-semibold leading-6 text-amber-900">
                  I certify that the information I have provided is true and accurate. Providing false information or impersonating another student may result in disciplinary action under school policies.
                </p>

                <button type="submit" class="mt-7 inline-flex w-full items-center justify-center gap-3 rounded-2xl bg-gradient-to-r from-eastBlue to-deepBlue px-7 py-4 text-base font-black text-white shadow-glow transition duration-200 hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-eastBlue/25 sm:w-auto">
                  Verify and Continue
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- New confidential reporting form with dynamic category details. -->
    <section id="reportView" class="view hidden min-h-screen px-5 py-8 sm:py-12">
      <div class="mx-auto w-full max-w-6xl">
        <header class="mb-7 flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-black uppercase tracking-[0.28em] text-eastBlue">Step 3</p>
            <h2 class="mt-3 text-4xl font-black text-slate-950 sm:text-5xl">Confidential Report</h2>
            <p class="mt-4 max-w-2xl text-base font-medium leading-7 text-slate-700">Your report will be routed only to authorized school officials for appropriate action.</p>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <button id="openTrackerButton" type="button" class="inline-flex h-12 w-12 items-center justify-center rounded-xl border border-blue-100 bg-white/80 text-eastBlue shadow-sm transition hover:-translate-y-0.5 hover:bg-white focus:outline-none focus:ring-4 focus:ring-eastBlue/15" aria-label="Track a report" title="Track a report">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 3-6.7" /><path d="M3 4v5h5" /><path d="M12 7v5l3 2" /></svg>
            </button>
            <div class="inline-flex items-center gap-3 rounded-2xl border border-blue-100 bg-white/80 px-4 py-3 shadow-sm backdrop-blur">
              <img src="evrshs-sslg-logo.jpg" alt="EVRSHS SSLG logo" class="logo-seal h-10 w-10 rounded-xl object-cover" />
              <div><p class="text-xs font-black uppercase tracking-[0.18em] text-eastBlue">SUMAT</p><p class="text-sm font-bold text-slate-700">Eastvicians</p></div>
            </div>
          </div>
        </header>

        <!-- Local tracker interface; a secure backend can replace local storage later. -->
        <section id="trackerPanel" class="glass-card relative mb-6 hidden overflow-hidden rounded-[1.5rem] p-6 sm:p-8">
          <div class="relative z-10 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <p class="text-sm font-black uppercase tracking-[0.2em] text-eastBlue">Track Report</p>
              <h3 class="mt-2 text-2xl font-black text-slate-950">Check a report status</h3>
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="status-pill">Pending</span><span class="status-pill">Under Review</span><span class="status-pill">Forwarded</span><span class="status-pill">Resolved</span><span class="status-pill">Closed</span>
              </div>
            </div>
            <form id="trackerForm" class="flex w-full max-w-xl flex-col gap-3 sm:flex-row">
              <label class="sr-only" for="trackingId">Report ID</label>
              <input id="trackingId" type="text" class="field min-w-0 flex-1 font-bold uppercase" placeholder="SUMAT-2026-000001" required />
              <button type="submit" class="rounded-2xl bg-eastBlue px-6 py-3 font-black text-white transition hover:bg-deepBlue focus:outline-none focus:ring-4 focus:ring-eastBlue/20">Check Status</button>
            </form>
          </div>
          <div id="trackerResult" class="relative z-10 mt-5 hidden rounded-2xl border border-blue-100 bg-white/80 p-4" aria-live="polite"></div>
        </section>

        <div class="glass-card overflow-hidden rounded-[2rem]">
          <form id="reportForm" class="relative z-10 grid gap-6 p-6 sm:p-8 lg:grid-cols-[0.85fr_1.15fr] lg:p-10" novalidate>
            <!-- Verification data flows straight into the API request body without asking the student again. -->
            <input id="submissionName" type="hidden" name="reporter_full_name" />
            <input id="submissionGrade" type="hidden" name="reporter_grade_level" />
            <input id="submissionSection" type="hidden" name="reporter_section" />
            <input id="submissionStudentId" type="hidden" name="reporter_student_id" />
            <input id="submissionPriority" type="hidden" name="report_priority" />

            <div class="space-y-6">
              <fieldset class="rounded-3xl border border-blue-100 bg-white/86 p-6 shadow-sm">
                <legend class="px-1 text-sm font-black uppercase tracking-[0.18em] text-eastBlue">Reporter Privacy Option *</legend>
                <div class="mt-4 grid gap-4">
                  <label class="block cursor-pointer">
                    <input class="privacy-input sr-only" name="privacy_mode" type="radio" value="Confidential Report" required />
                    <span class="privacy-card block rounded-2xl border border-blue-100 bg-white p-4 transition">
                      <span class="flex items-start gap-3">
                        <span class="privacy-check mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full border-2 border-blue-200 text-xs font-black">A</span>
                        <span><strong class="block text-base text-slate-950">Confidential Report</strong><span class="mt-1 block text-sm leading-6 text-slate-600">My identity is visible only to authorized school officials, never to the accused person or other students. Faster investigation.</span></span>
                      </span>
                    </span>
                  </label>
                  <label class="block cursor-pointer">
                    <input class="privacy-input sr-only" name="privacy_mode" type="radio" value="Confidential Identity - Initial Review" required />
                    <span class="privacy-card block rounded-2xl border border-blue-100 bg-white p-4 transition">
                      <span class="flex items-start gap-3">
                        <span class="privacy-check mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full border-2 border-blue-200 text-xs font-black">B</span>
                        <span><strong class="block text-base text-slate-950">Confidential Identity</strong><span class="mt-1 block text-sm leading-6 text-slate-600">Hide my identity during initial review. Officials may request it only when absolutely necessary under school policies. Investigation may take longer.</span></span>
                      </span>
                    </span>
                  </label>
                </div>
              </fieldset>

              <div class="rounded-3xl border border-blue-100 bg-white/86 p-6 shadow-sm">
                <p class="text-sm font-black uppercase tracking-[0.18em] text-eastBlue">Confidential Handling</p>
                <p class="mt-3 text-sm font-semibold leading-6 text-slate-700">Your personal information is protected and handled confidentially. Only authorized school officials may access reporter information when necessary in accordance with school policies.</p>
                <p class="mt-3 text-sm leading-6 text-slate-600">Report details: Principal, Guidance Counselor, Child Protection Committee, and Designated School Administrator. SSLG officers: statistics and counts only.</p>
              </div>

              <div class="rounded-3xl border border-blue-100 bg-white/86 p-6 shadow-sm">
                <label class="field-label" for="reportCategory">Report Category *</label>
                <select id="reportCategory" name="report_category" class="field" required>
                  <option value="" selected disabled>Select a category</option>
                  <optgroup label="Bullying and Protection"><option value="bullying">Bullying and Harassment - Bullying, Cyberbullying, Discrimination, Intimidation</option><option value="child-protection">Child Protection Concern - Abuse, Exploitation, Inappropriate Behavior</option></optgroup>
                  <optgroup label="Campus and Safety"><option value="facilities">School Facilities and Maintenance - Chairs, Windows, Classrooms, Comfort Rooms, Roofs, Electrical</option><option value="safety">Safety and Security - Unsafe Areas, Hazards, Suspicious Persons, Emergencies</option><option value="environment">Environmental Concern - Waste, Cleanliness, Drainage, Tree Protection</option><option value="health">Health and Sanitation - Food Safety, Water, Hygiene, Clinic</option><option value="ict">ICT and Technology - Internet, Wi-Fi, Computers, System Bugs, Projectors</option></optgroup>
                  <optgroup label="School Community"><option value="academic">Academic Concerns - Classroom, Assessment, Scheduling, Learning Environment</option><option value="teacher">Teacher or Staff Concern - Conduct, Communication, Confidential Concerns</option><option value="student-conduct">Student Conduct - Fighting, Smoking, Cheating, Vandalism, Misconduct</option></optgroup>
                  <optgroup label="Feedback"><option value="suggestion">Suggestions and Recommendations</option><option value="appreciation">Appreciation and Recognition</option><option value="event-feedback">School Event Feedback</option><option value="sslg-feedback">SSLG Programs and Services</option><option value="others">Others</option></optgroup>
                </select>
                <div id="priorityWrap" class="mt-4 hidden"><span id="priorityBadge" class="priority-badge"></span></div>
              </div>
            </div>

            <div class="space-y-6">
              <div class="rounded-3xl border border-blue-100 bg-white/86 p-6 shadow-sm">
                <div class="grid gap-5 sm:grid-cols-2">
                  <div class="sm:col-span-2">
                    <label id="titleLabel" class="field-label" for="reportTitle">Report Title *</label>
                    <input id="reportTitle" name="report_title" type="text" class="field" placeholder="Briefly describe the concern" required />
                  </div>
                  <div>
                    <label id="dateLabel" class="field-label" for="reportDate">Relevant Date</label>
                    <input id="reportDate" name="report_date" type="date" class="field" />
                  </div>
                  <div>
                    <label id="locationLabel" class="field-label" for="reportLocation">Relevant Location</label>
                    <input id="reportLocation" name="report_location" type="text" class="field" placeholder="Building, room, or area" />
                  </div>
                </div>
              </div>

              <!-- JavaScript inserts only the category-specific fields requested in the brief. -->
              <div id="dynamicFields" class="hidden rounded-3xl border border-blue-100 bg-white/86 p-6 shadow-sm"></div>

              <div class="rounded-3xl border border-blue-100 bg-white/86 p-6 shadow-sm">
                <label id="descriptionLabel" class="field-label" for="reportDescription">Report Description *</label>
                <textarea id="reportDescription" name="report_description" class="field min-h-44 resize-y leading-7" placeholder="Provide clear, factual details that can help the school review this concern." required></textarea>
              </div>

              <div class="rounded-3xl border border-blue-100 bg-white/86 p-6 shadow-sm">
                <label class="field-label" for="evidenceFiles">Supporting Evidence Uploads</label>
                <input id="evidenceFiles" name="evidence_files[]" type="file" class="field file-input cursor-pointer" accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt" multiple />
                <p class="mt-3 text-sm font-semibold leading-6 text-slate-600">Photos, videos, screenshots, audio recordings, PDFs, and documents are accepted.</p>
                <p id="evidenceSummary" class="mt-2 text-sm font-black text-eastBlue">No files selected.</p>
              </div>

              <div id="validationMessage" class="hidden rounded-2xl border border-red-200 bg-red-50 p-4 text-sm font-semibold leading-6 text-red-800" role="alert"></div>

              <div class="rounded-3xl bg-gradient-to-r from-deepBlue to-eastBlue p-5 text-white shadow-glow">
                <p class="text-sm font-black uppercase tracking-[0.18em] text-eastYellow">Submission Reminder</p>
                <p class="mt-2 text-sm leading-6 text-blue-50">Submitting false, malicious, or misleading reports may result in disciplinary action under school policies.</p>
                <button type="submit" class="mt-5 inline-flex w-full items-center justify-center gap-3 rounded-2xl bg-eastYellow px-6 py-4 text-base font-black text-deepBlue shadow-gold transition duration-200 hover:-translate-y-0.5 hover:bg-yellow-300 focus:outline-none focus:ring-4 focus:ring-eastYellow/40 sm:w-auto">
                  <span class="grid h-7 w-7 place-items-center rounded-full bg-white/85" aria-hidden="true"><svg class="h-4 w-4" viewBox="0 0 20 20" fill="none"><rect x="4.6" y="8.2" width="10.8" height="8.2" rx="2" stroke="currentColor" stroke-width="2" /><path d="M7.2 8.2V6.1a2.8 2.8 0 0 1 5.6 0v2.1" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg></span>
                  Submit Confidential Report
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- New success state shown after the API confirms the report was saved. -->
    <section id="successView" class="view hidden min-h-screen px-5 py-10">
      <div class="mx-auto flex min-h-[calc(100vh-5rem)] max-w-3xl items-center justify-center">
        <div class="glass-card w-full overflow-hidden rounded-[2rem] p-8 text-center sm:p-12">
          <div class="relative z-10">
            <div class="animate-success-pop mx-auto grid h-24 w-24 place-items-center rounded-[2rem] bg-emerald-100 text-emerald-700 shadow-lg">
              <svg class="h-12 w-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="m5 12 4.2 4.2L19 6.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </div>
            <p class="mt-8 text-sm font-black uppercase tracking-[0.26em] text-eastBlue">Report Submitted</p>
            <h2 class="mt-3 text-3xl font-black text-slate-950 sm:text-4xl">Thank you for speaking up.</h2>
            <p class="mx-auto mt-4 max-w-xl text-base font-semibold leading-7 text-slate-700">Your report has been successfully submitted and will be handled confidentially.</p>
            <div class="mx-auto mt-8 max-w-md rounded-3xl border border-blue-100 bg-white/85 p-5 shadow-sm">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-eastBlue">Report ID</p>
              <p id="successReportId" class="mt-2 break-all text-2xl font-black text-deepBlue sm:text-3xl"></p>
              <button id="copyReportIdButton" type="button" class="mt-4 inline-flex items-center justify-center rounded-xl border border-blue-100 bg-blue-50 px-4 py-2 text-sm font-black text-eastBlue transition hover:bg-white focus:outline-none focus:ring-4 focus:ring-eastBlue/15">Copy Report ID</button>
            </div>
            <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
              <button id="trackSubmittedButton" type="button" class="rounded-2xl bg-eastBlue px-6 py-3 font-black text-white transition hover:bg-deepBlue focus:outline-none focus:ring-4 focus:ring-eastBlue/20">Track This Report</button>
              <button id="newReportButton" type="button" class="rounded-2xl border border-blue-100 bg-white/85 px-6 py-3 font-black text-eastBlue transition hover:bg-white focus:outline-none focus:ring-4 focus:ring-eastBlue/15">Submit Another Report</button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    // Major modification: view flow now adds consent -> verification -> confidential report -> success.
    const introView = document.getElementById('introView');
    const consentView = document.getElementById('consentView');
    const verificationView = document.getElementById('verificationView');
    const reportView = document.getElementById('reportView');
    const successView = document.getElementById('successView');
    const agreeButton = document.getElementById('agreeButton');
    const verificationForm = document.getElementById('verificationForm');
    const reportForm = document.getElementById('reportForm');
    const reportCategory = document.getElementById('reportCategory');
    const dynamicFields = document.getElementById('dynamicFields');
    const priorityWrap = document.getElementById('priorityWrap');
    const priorityBadge = document.getElementById('priorityBadge');
    const evidenceFiles = document.getElementById('evidenceFiles');
    const evidenceSummary = document.getElementById('evidenceSummary');
    const validationMessage = document.getElementById('validationMessage');
    const trackerPanel = document.getElementById('trackerPanel');
    const trackerForm = document.getElementById('trackerForm');
    const trackerResult = document.getElementById('trackerResult');
    const trackingId = document.getElementById('trackingId');
    const successReportId = document.getElementById('successReportId');
    const copyReportIdButton = document.getElementById('copyReportIdButton');

    const verifiedStudent = {};
    let activeReportId = '';

    function showView(view) {
      view.classList.remove('hidden');
      view.style.display = 'block';
      requestAnimationFrame(() => view.classList.add('is-visible'));
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function hideView(view, afterHide) {
      view.classList.remove('is-visible');
      window.setTimeout(() => {
        view.classList.add('hidden');
        view.style.display = 'none';
        if (afterHide) afterHide();
      }, 540);
    }

    function switchView(fromView, toView) {
      hideView(fromView, () => showView(toView));
    }

    window.addEventListener('load', () => {
      window.setTimeout(() => switchView(introView, consentView), 5600);
    });

    agreeButton.addEventListener('click', () => switchView(consentView, verificationView));

    // Major modification: student verification replaces the former anonymous-only entry point.
    verificationForm.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!verificationForm.checkValidity()) {
        verificationForm.reportValidity();
        return;
      }

      verifiedStudent.name = document.getElementById('verifiedName').value.trim();
      verifiedStudent.grade = document.getElementById('verifiedGrade').value;
      verifiedStudent.section = document.getElementById('verifiedSection').value.trim();
      verifiedStudent.studentId = document.getElementById('verifiedId').value.trim();
      populateSubmissionFields();
      switchView(verificationView, reportView);
    });

    // Major modification: category map controls dynamic fields, priorities, and labels.
    const categoryConfig = {
      bullying: { priority: 'high', label: 'High Priority', title: 'Incident Title', date: 'Incident Date', location: 'Incident Location', description: 'Incident Description', fields: `
        <p class="field-label">Bullying Incident Details</p>
        <div class="grid gap-5 sm:grid-cols-2">
          <div><label class="field-label" for="incidentTime">Incident Time</label><input id="incidentTime" name="incident_time" type="time" class="field" /></div>
          <div><label class="field-label" for="personsInvolved">Persons Involved</label><input id="personsInvolved" name="persons_involved" type="text" class="field" placeholder="Names or descriptions" /></div>
          <div class="sm:col-span-2"><label class="field-label" for="witnesses">Witnesses</label><input id="witnesses" name="witnesses" type="text" class="field" placeholder="Names or descriptions, if any" /></div>
        </div>` },
      'child-protection': { priority: 'high', label: 'High Priority', title: 'Protection Concern Title', date: 'Relevant Date', location: 'Relevant Location', description: 'Concern Description', fields: `
        <p class="field-label">Child Protection Details</p>
        <div><label class="field-label" for="protectionPeople">Persons Involved</label><input id="protectionPeople" name="persons_involved" type="text" class="field" placeholder="Names or descriptions" /></div>` },
      facilities: { priority: 'medium', label: 'Medium Priority', title: 'Facility Issue Title', date: 'Date Observed', location: 'Building and Room', description: 'Problem Description', fields: `
        <p class="field-label">Facilities Details</p>
        <div class="grid gap-5 sm:grid-cols-2">
          <div><label class="field-label" for="building">Building</label><input id="building" name="building" type="text" class="field" required /></div>
          <div><label class="field-label" for="roomNumber">Room Number</label><input id="roomNumber" name="room_number" type="text" class="field" required /></div>
        </div>` },
      safety: { priority: 'high', label: 'High Priority', title: 'Safety Concern Title', date: 'Date Observed', location: 'Hazard Location', description: 'Hazard Description', fields: `
        <p class="field-label">Safety Details</p>
        <div class="grid gap-5 sm:grid-cols-2">
          <div><label class="field-label" for="immediateDanger">Immediate Danger?</label><select id="immediateDanger" name="immediate_danger" class="field" required><option value="" selected disabled>Select</option><option value="Yes">Yes</option><option value="No">No</option></select></div>
          <div><label class="field-label" for="hazardType">Hazard Type</label><input id="hazardType" name="hazard_type" type="text" class="field" placeholder="Describe the hazard" /></div>
        </div>` },
      suggestion: { priority: 'low', label: 'Low Priority', title: 'Suggestion Title', date: 'Relevant Date', location: 'Relevant Area', description: 'Suggestion', fields: `
        <p class="field-label">Suggestion Details</p>
        <div class="grid gap-5">
          <div><label class="field-label" for="expectedBenefits">Expected Benefits</label><textarea id="expectedBenefits" name="expected_benefits" class="field min-h-28 resize-y" required></textarea></div>
          <div><label class="field-label" for="estimatedImpact">Estimated Impact</label><input id="estimatedImpact" name="estimated_impact" type="text" class="field" placeholder="Who or what may benefit?" required /></div>
        </div>` },
      appreciation: { priority: 'low', label: 'Low Priority', title: 'Recognition Title', date: 'Relevant Date', location: 'Relevant Place', description: 'Optional Message', optionalDescription: true, fields: `
        <p class="field-label">Recognition Details</p>
        <div class="grid gap-5 sm:grid-cols-2">
          <div><label class="field-label" for="recognizedPerson">Who are you recognizing?</label><input id="recognizedPerson" name="recognized_person" type="text" class="field" required /></div>
          <div><label class="field-label" for="recognitionReason">Reason</label><input id="recognitionReason" name="recognition_reason" type="text" class="field" required /></div>
        </div>` },
      teacher: { priority: 'medium', label: 'Medium Priority', title: 'Teacher or Staff Concern Title', date: 'Relevant Date', location: 'Location', description: 'Concern Description', fields: `
        <p class="field-label">Teacher or Staff Details</p>
        <div class="grid gap-5 sm:grid-cols-2">
          <div><label class="field-label" for="staffName">Teacher or Staff Name</label><input id="staffName" name="teacher_staff_name" type="text" class="field" required /></div>
          <div><label class="field-label" for="department">Department</label><input id="department" name="department" type="text" class="field" required /></div>
        </div>` },
      others: { priority: 'medium', label: 'Medium Priority', title: 'Report Title', date: 'Relevant Date', location: 'Relevant Location', description: 'Description', fields: '' },
      academic: { priority: 'medium', label: 'Medium Priority', title: 'Academic Concern Title', date: 'Relevant Date', location: 'Classroom or Area', description: 'Concern Description', fields: '' },
      environment: { priority: 'medium', label: 'Medium Priority', title: 'Environmental Concern Title', date: 'Date Observed', location: 'Affected Location', description: 'Concern Description', fields: '' },
      health: { priority: 'medium', label: 'Medium Priority', title: 'Health or Sanitation Concern Title', date: 'Date Observed', location: 'Affected Location', description: 'Concern Description', fields: '' },
      ict: { priority: 'medium', label: 'Medium Priority', title: 'ICT Concern Title', date: 'Date Observed', location: 'Room or System', description: 'Concern Description', fields: '' },
      'student-conduct': { priority: 'medium', label: 'Medium Priority', title: 'Student Conduct Concern Title', date: 'Incident Date', location: 'Incident Location', description: 'Concern Description', fields: '' },
      'event-feedback': { priority: 'low', label: 'Low Priority', title: 'Event Feedback Title', date: 'Event Date', location: 'Event Venue', description: 'Feedback', fields: '' },
      'sslg-feedback': { priority: 'low', label: 'Low Priority', title: 'SSLG Program or Service Title', date: 'Relevant Date', location: 'Relevant Area', description: 'Feedback', fields: '' }
    };

    function updateCategoryForm() {
      const config = categoryConfig[reportCategory.value];
      if (!config) return;
      document.getElementById('titleLabel').textContent = `${config.title} *`;
      document.getElementById('dateLabel').textContent = config.date;
      document.getElementById('locationLabel').textContent = config.location;
      const descriptionField = document.getElementById('reportDescription');
      descriptionField.required = !config.optionalDescription;
      document.getElementById('descriptionLabel').textContent = config.optionalDescription ? config.description : `${config.description} *`;
      document.getElementById('reportTitle').placeholder = config.title;
      document.getElementById('reportLocation').placeholder = config.location;
      descriptionField.placeholder = config.optionalDescription
        ? 'Add an optional message.'
        : `Provide clear, factual details about this ${config.description.toLowerCase()}.`;
      dynamicFields.innerHTML = config.fields;
      dynamicFields.classList.toggle('hidden', !config.fields);
      priorityBadge.className = `priority-badge priority-${config.priority}`;
      priorityBadge.textContent = config.label;
      priorityWrap.classList.remove('hidden');
      document.getElementById('submissionPriority').value = config.label;
    }

    reportCategory.addEventListener('change', updateCategoryForm);

    evidenceFiles.addEventListener('change', () => {
      const count = evidenceFiles.files.length;
      evidenceSummary.textContent = count === 0 ? 'No files selected.' : `${count} file${count === 1 ? '' : 's'} selected for upload.`;
    });

    function showValidationMessage(message) {
      validationMessage.textContent = message;
      validationMessage.classList.remove('hidden');
      validationMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function clearValidationMessage() {
      validationMessage.textContent = '';
      validationMessage.classList.add('hidden');
    }

    // Major modification: anti-spam validation requires description and verifiable support.
    function hasSupportingEvidence() {
      const hasUpload = evidenceFiles.files.length > 0;
      const witnessField = document.getElementById('witnesses');
      const hasWitness = witnessField && witnessField.value.trim().length > 0;
      const hasDateAndLocation = document.getElementById('reportDate').value && document.getElementById('reportLocation').value.trim();
      return hasUpload || hasWitness || hasDateAndLocation;
    }

    function hasRequiredDescription() {
      const description = document.getElementById('reportDescription').value.trim();
      const recognitionReason = document.getElementById('recognitionReason');
      return description.length > 0 || (reportCategory.value === 'appreciation' && recognitionReason && recognitionReason.value.trim().length > 0);
    }

    // Major modification: the report now posts to the real backend API. The server generates
    // the Report ID, assigns priority authoritatively, and persists the record in PostgreSQL,
    // so the Student Portal and Admin Dashboard share exactly the same data.
    reportForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearValidationMessage();

      if (!reportForm.checkValidity()) {
        reportForm.reportValidity();
        return;
      }

      if (!hasRequiredDescription()) {
        showValidationMessage('Please provide a clear description of the report or a recognition reason.');
        return;
      }

      if (!hasSupportingEvidence()) {
        showValidationMessage('Please provide at least one supporting item: a photo, screenshot, document, other upload, witness, or both a date and location.');
        return;
      }

      const submitButton = reportForm.querySelector('button[type="submit"]');
      const originalButtonText = submitButton.textContent.trim();
      submitButton.disabled = true;
      submitButton.textContent = 'Submitting Report...';

      const formData = new FormData(reportForm);
      formData.set('report_category', reportCategory.value);

      try {
        const response = await fetch(`${window.SUMAT_CONFIG.API_BASE}/reports`, { method: 'POST', body: formData });
        const result = await response.json();
        if (!response.ok) throw new Error(result.error || 'The report could not be submitted.');

        activeReportId = result.report_id;
        successReportId.textContent = activeReportId;
        switchView(reportView, successView);
      } catch (error) {
        showValidationMessage(error.message || 'Your report could not be sent right now. Please check your internet connection and try again.');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = originalButtonText;
      }
    });

    // Major modification: tracking now reads live status from the backend instead of local storage.
    function openTracker(prefillId = '') {
      trackerPanel.classList.remove('hidden');
      trackingId.value = prefillId;
      trackerPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (prefillId) trackerForm.requestSubmit();
    }

    document.getElementById('openTrackerButton').addEventListener('click', () => openTracker());

    trackerForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const requestedId = trackingId.value.trim().toUpperCase();
      trackerResult.classList.remove('hidden');
      trackerResult.innerHTML = '<p class="text-sm font-semibold text-slate-600">Checking status...</p>';

      try {
        const response = await fetch(`${window.SUMAT_CONFIG.API_BASE}/reports/track/${encodeURIComponent(requestedId)}`);
        const record = await response.json();
        if (!response.ok) throw new Error(record.error || 'No report found with that Report ID.');

        const timeline = (record.timeline || [])
          .map((item) => `<p class="mt-1 text-xs font-semibold text-slate-500">${item.status} - ${new Date(item.timestamp).toLocaleString()}</p>`)
          .join('');

        trackerResult.innerHTML = `<p class="text-sm font-black uppercase tracking-[0.16em] text-eastBlue">${record.report_id}</p><p class="mt-2 text-xl font-black text-slate-950">Status: <span class="status-pill">${record.status}</span></p><p class="mt-2 text-sm font-semibold text-slate-600">Submitted ${new Date(record.created_at).toLocaleString()}.</p><div class="mt-3">${timeline}</div>`;
      } catch (error) {
        trackerResult.innerHTML = `<p class="text-sm font-bold text-slate-700">${error.message || 'No matching report record was found.'}</p>`;
      }
    });

    copyReportIdButton.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(activeReportId);
        copyReportIdButton.textContent = 'Copied';
      } catch {
        copyReportIdButton.textContent = activeReportId;
      }
      window.setTimeout(() => { copyReportIdButton.textContent = 'Copy Report ID'; }, 1600);
    });

    document.getElementById('trackSubmittedButton').addEventListener('click', () => switchView(successView, reportView));
    document.getElementById('trackSubmittedButton').addEventListener('click', () => window.setTimeout(() => openTracker(activeReportId), 650));

    function populateSubmissionFields() {
      document.getElementById('submissionName').value = verifiedStudent.name || '';
      document.getElementById('submissionGrade').value = verifiedStudent.grade || '';
      document.getElementById('submissionSection').value = verifiedStudent.section || '';
      document.getElementById('submissionStudentId').value = verifiedStudent.studentId || '';
    }

    document.getElementById('newReportButton').addEventListener('click', () => {
      reportForm.reset();
      populateSubmissionFields();
      dynamicFields.innerHTML = '';
      dynamicFields.classList.add('hidden');
      priorityWrap.classList.add('hidden');
      evidenceSummary.textContent = 'No files selected.';
      document.getElementById('titleLabel').textContent = 'Report Title *';
      document.getElementById('dateLabel').textContent = 'Relevant Date';
      document.getElementById('locationLabel').textContent = 'Relevant Location';
      document.getElementById('descriptionLabel').textContent = 'Report Description *';
      document.getElementById('reportDescription').required = true;
      clearValidationMessage();
      switchView(successView, reportView);
    });
  </script>
</body>
</html>
